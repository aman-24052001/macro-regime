# ── Config with secrets ───────────────────────────────────────
# config.yaml contains FRED API key — use config/config.template.yaml
config/config.yaml

# ── Data cache (large files, re-downloadable) ─────────────────
data/raw/
data/processed/

# ── Model artifacts ───────────────────────────────────────────
outputs/models/*.pkl
# regime_probs.csv is re-generated by --phase model
outputs/models/regime_probs.csv

# ── Generated reports (large or auto-generated) ───────────────
# tearsheet.html is 700KB quantstats HTML — re-run interpret to regenerate
outputs/reports/tearsheet.html

# ── Dev logs ─────────────────────────────────────────────────
outputs/*.log

# ── Session notes (internal) ──────────────────────────────────
status/*_status.txt

# ── Python ───────────────────────────────────────────────────
__pycache__/
*.py[cod]
*.so
.Python
*.egg-info/
dist/
build/
.eggs/

# ── Virtual env ───────────────────────────────────────────────
venv/
.venv/
env/
.env

# ── Jupyter ───────────────────────────────────────────────────
.ipynb_checkpoints/
*.ipynb_checkpoints

# ── IDE ───────────────────────────────────────────────────────
.vscode/
.idea/
*.swp
*.swo

# ── Claude Code (local agent settings) ───────────────────────
.claude/

# ── OS ────────────────────────────────────────────────────────
.DS_Store
Thumbs.db
